{
  "name": "express-start-kit",
  "version": "1.0.0",
  "description": "Start your next project in seconds",
  "main": "index.js",
  "author": "danh.danh20051995@gmail.com",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danh20051995/express-start-kit.git"
  },
  "homepage": "https://github.com/danh20051995/express-start-kit#readme",
  "bugs": {
    "url": "https://github.com/danh20051995/express-start-kit/issues"
  },
  "keywords": [
    "express",
    "nodejs",
    "babel",
    "mongodb",
    "postgresql",
    "redis",
    "RESTful"
  ],
  "engines": {
    "node": ">=12.16.2"
  },
  "lint-staged": {
    "!(log|temp|public|ecosystem.config)*.+(js|jsx|ts)": [
      "eslint --report-unused-disable-directives --max-warnings 0"
    ]
  },
  "_moduleAliases": {
    "@": "src"
  },
  "scripts": {
    "postinstall": "node .postinstall",
    "initial": "node .initial",
    "preserve": "npm run initial --scripts-prepend-node-path",
    "prestart": "npm run initial --scripts-prepend-node-path",
    "seed": "sequelize db:seed:all",
    "migrate": "sequelize db:migrate",
    "migrate:undo": "sequelize db:migrate:undo",
    "serve": "node index.js",
    "start": "nodemon --exec npm run watch",
    "watch": "npm-run-all --serial eslint dev",
    "dev": "cross-env NODE_ENV=development node --inspect=0.0.0.0:9229 index.js",
    "staging": "cross-env NODE_ENV=staging node index.js",
    "production": "cross-env NODE_ENV=production node index.js",
    "eslint": "eslint . --format node_modules/eslint-friendly-formatter",
    "eslint-fix": "eslint . --format node_modules/eslint-friendly-formatter --fix"
  },
  "dependencies": {
    "axios": "^0.21.1",
    "bcrypt": "^5.0.1",
    "busboy": "^0.2.14",
    "config": "^3.3.6",
    "cors": "^2.8.5",
    "dotenv": "^9.0.2",
    "express": "^4.17.1",
    "ioredis": "^4.27.2",
    "joi": "^17.4.0",
    "jsonwebtoken": "^8.5.1",
    "lodash": "^4.17.21",
    "module-alias": "^2.2.2",
    "moment": "^2.29.1",
    "moment-timezone": "^0.5.33",
    "mongoose": "^5.12.10",
    "node-rsa": "^1.1.1",
    "nodemailer": "^6.6.0",
    "pg": "^8.6.0",
    "pg-hstore": "^2.3.3",
    "rsmq": "^0.12.3",
    "sequelize": "^6.6.2",
    "sharp": "^0.28.1",
    "slugify": "^1.5.3",
    "swagger-ui-dist": "^3.48.0",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@babel/core": "^7.14.0",
    "@babel/eslint-parser": "^7.13.14",
    "@babel/plugin-proposal-class-properties": "^7.13.0",
    "@babel/plugin-proposal-object-rest-spread": "^7.13.8",
    "@babel/plugin-transform-runtime": "^7.13.15",
    "@babel/preset-env": "^7.14.1",
    "@babel/register": "^7.13.16",
    "@babel/runtime": "^7.14.0",
    "cross-env": "^7.0.3",
    "eslint": "^7.25.0",
    "eslint-config-standard": "^16.0.2",
    "eslint-friendly-formatter": "^4.0.1",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^4.3.1",
    "husky": "^6.0.0",
    "lint-staged": "^10.5.4",
    "nodemon": "^2.0.7",
    "npm-run-all": "^4.1.5",
    "sequelize-cli": "^6.2.0"
  }
}
