    "nodejs",
    "mongodb",
    "redis",
    "RESTful"
  ],
  "pre-commit": [
    "eslint"
  ],
  "scripts": {
    "eslint": "eslint --format node_modules/eslint-friendly-formatter index.js app/",
    "start": "nodemon --exec npm-run-all --parallel dev eslint",
    "dev": "cross-env NODE_ENV=development node --inspect=0.0.0.0:9229 index.js",
    "staging": "cross-env NODE_ENV=staging node index.js",
    "production": "cross-env NODE_ENV=production node index.js"
  },
  "_moduleAliases": {
    "_root": ".",
    "_utils": "app/utils",
    "_module": "app/module"
  },
  "dependencies": {
    "async": "^3.1.1",
    "bcrypt": "^5.0.0",
    "body-parser": "^1.18.3",
    "config": "^2.0.1",
    "connect-flash": "^0.1.1",
    "cookie-parser": "^1.4.3",
    "cors": "^2.8.5",
    "express": "^4.16.3",
    "express-boom": "^2.0.0",
    "express-session": "^1.15.6",
    "express-validation": "^1.0.2",
    "ioredis": "^4.9.0",
    "joi": "^14.0.1",
    "jsonwebtoken": "^8.4.0",
    "lodash": "^4.17.11",
    "moment": "^2.22.2",
    "mongoose": "^5.3.1",
    "multer": "^1.4.1",
    "nunjucks": "^3.1.3",
    "sharp": "^0.24.1"
